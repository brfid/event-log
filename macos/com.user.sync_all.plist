<!-- 
- `com.user.sync_all.plist`
- copy to `~/Library/LaunchAgents` to run logged in and awake
- 
-->

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.configsync</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3.11</string>
        <!-- *** Update home path or use a wrapper script *** -->
        <string>$HOME/.config/scripts/sync_all.py</string>
    </array>
    <key>StartInterval</key>
    <integer>600</integer>
    <key>StandardOutPath</key>
    <string>/tmp/config_sync_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/config_sync_stderr.log</string>
    <key>RunAtLoad</key>
    <true/>
    <key>WorkingDirectory</key>
    <!-- *** Update home path or use a wrapper script *** -->
    <string>$HOME/.config/scripts</string>
</dict>
</plist>